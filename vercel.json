{
  "framework": "vite",
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "crons": [
    { "path": "/api/v1/cron/expire-deals", "schedule": "0 0 * * *" },
    { "path": "/api/v1/cron/send-reminders", "schedule": "0 8 * * *" },
    { "path": "/api/v1/cron/cleanup", "schedule": "0 3 * * *" }
  ]
}
